  "keyFeatures": [
    "Google OAuth 2.0 authentication",
    "Multi-wallet support with per-user wallet assignment",
    "Transaction logging with income and expense tracking",
    "Category and tag system for organizing transactions",
    "Interactive calendar view with daily spending totals",
    "Monthly spending charts and analytics",
    "Timezone-aware date handling",
    "Docker-based deployment with MySQL backend"
  ],
